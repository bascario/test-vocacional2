{
    "require": {
        "php": ">=7.4",
        "tecnickcom/tcpdf": "^6.4",
        "phpoffice/phpspreadsheet": "^5.1",
        "phpoffice/phpword": "^1.4"
    },
    "require-dev": {
        "phpunit/phpunit": "9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "./"
        },
        "files": [
            "config/config.php",
            "config/database.php"
        ],
        "classmap": [
            "models/",
            "controllers/",
            "utils/",
            "middleware/"
        ]
    },
    "scripts": {
        "test": "phpunit --colors=always"
    }
}
